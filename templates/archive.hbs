<!DOCTYPE html>
<html>

<head>
    <title>Archive</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600&family=Roboto+Mono:ital,wght@0,100..700;1,100..700&family=Roboto:wght@900&family=Rochester&family=Saira+Stencil+One&display=swap"
        rel="stylesheet">

    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">


    <link rel="stylesheet" type="text/css" href="css/bulma.min.css">

    <link rel="stylesheet" type="text/css" href="css/main.css">

    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">


</head>

<body>
    <nav class="navbar">
        <div class="container">
            <div class="navbar-brand">
                <a class="navbar-item" id="nav_logo" href="../">
                    <img src="images/logo.png" alt="Logo">
                </a>
                <span class="navbar-burger burger" data-target="navbarMenu">
                    <span></span>
                    <span></span>
                    <span></span>
                </span>
            </div>
            <div id="navbarMenu" class="navbar-menu">
                <div class="navbar-end">
                    <a class="navbar-item" href="/">
                        ~/
                    </a>
                    <a class="navbar-item" href="/archive">
                        ~/archive
                    </a>
                    <a class="navbar-item" href="/tags">
                        ~/tags
                    </a>
                    <a class="navbar-item" href="/about">
                        ~/about
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div id="world"></div>
    <section class="hero is-info is-medium is-bold">
        <div class="hero-body has-text-centered">

        </div>
    </section>


    <section class="articles">
        {{#each years}}

        <div class="column is-8 is-offset-2">

            <!-- START ARTICLE -->
            <div class="card article">
                <div class="card-content">
                    <div class="title">{{year}}</div>

                    <div class="media">

                        <div class="media-content has-text-centered">

                            {{#each articles}}
                            <article>
                                <div class="title_box">
                                    <a href="w/{{URL}}">

                                        <div class="title">{{Title}}</div>
                                    </a>

                                    <div class="date"><time datetime={{Date}}>{{humandate}}</time></div>
                                </div>
                                <div class="tldr">{{TLDR}}</div>

                                <div class="has-text-centered">
                                    {{#each Tags}}
                                    <a href="/tags/{{this}}/" class="tag">{{this}}</a>
                                    {{/each}}

                            </article>


                            {{/each}}

                        </div>
                    </div>

                </div>
            </div>
        </div>
        {{/each}}

        </div>

    </section>
    </main>
    <footer>
        <!-- Footer content -->
    </footer>
    <script src="/bundle.js"></script>
</body>

</html>