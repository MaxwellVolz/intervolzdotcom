{
  "name": "intervolzdotcom",
  "version": "1.0.0",
  "description": "website",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npm run watch\" \"npm run serve\"",
    "dev": "nodemon server.js",
    "build": "npm run generate-content && webpack --mode production",
    "serve": "serve public",
    "watch": "nodemon --watch articles --watch templates --ext js,json,md,hbs --exec npm run build",
    "generate-content": "node scripts/generate_content.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InterVolz/intervolzdotcom.git"
  },
  "keywords": [
    "tech"
  ],
  "author": "Maxwell Volz",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/InterVolz/intervolzdotcom/issues"
  },
  "homepage": "https://github.com/InterVolz/intervolzdotcom#readme",
  "dependencies": {
    "d3": "^7.9.0",
    "handlebars": "^4.7.8",
    "markdown-it": "^14.0.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.6",
    "autoprefixer": "^10.4.19",
    "babel-loader": "^9.1.3",
    "bulma": "^1.0.1",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "highlight.js": "^11.9.0",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "markdown-it-anchor": "^8.6.7",
    "mini-css-extract-plugin": "^2.9.0",
    "nodemon": "^3.0.2",
    "postcss-loader": "^7.1.3",
    "sass": "^1.77.2",
    "sass-loader": "^13.3.2",
    "style-loader": "^4.0.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-shell-plugin-next": "^2.3.1"
  }
}
